<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650" prefWidth="950" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.proyecto_poo.controller.ProfesorController">

    <children>
        <!-- TÍTULO Y SUBTÍTULO -->
        <VBox AnchorPane.leftAnchor="40" AnchorPane.topAnchor="10">
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Gestión de Profesores" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #8b95a5; -fx-padding: 5 0 0 0;" text="Administra, registra y actualiza la información de los docentes del sistema." />
        </VBox>

        <!-- CONTENEDOR PRINCIPAL PARA LAS DOS TARJETAS -->
        <HBox spacing="20" AnchorPane.bottomAnchor="30" AnchorPane.leftAnchor="40" AnchorPane.rightAnchor="40" AnchorPane.topAnchor="90">

            <!-- TARJETA IZQUIERDA: FORMULARIO -->
            <VBox prefWidth="350" spacing="14" style="-fx-background-color: #1a1c35; -fx-background-radius: 12; -fx-border-color: #2a2e4d; -fx-border-radius: 12; -fx-border-width: 1;">

                <padding>
                    <Insets bottom="20" left="25" right="25" top="20" />
                </padding>

                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 2 0;" text="Información del Profesor" />

                <!-- Campos de entrada -->
                <VBox spacing="6">
                    <Label style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px; -fx-font-weight: bold;" text="Nombre" />
                    <TextField fx:id="txtNombre" prefHeight="38" promptText="Ingrese el nombre" style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: white; -fx-prompt-text-fill: #64748b;" />
                </VBox>

                <VBox spacing="6">
                    <Label style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px; -fx-font-weight: bold;" text="Apellido" />
                    <TextField fx:id="txtApellido" prefHeight="38" promptText="Ingrese el apellido" style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: white; -fx-prompt-text-fill: #64748b;" />
                </VBox>

                <VBox spacing="6">
                    <Label style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px; -fx-font-weight: bold;" text="Cédula" />
                    <TextField fx:id="txtCedula" prefHeight="38" promptText="Ingrese la cédula" style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: white; -fx-prompt-text-fill: #64748b;" />
                </VBox>

                <VBox spacing="6">
                    <Label style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px; -fx-font-weight: bold;" text="Especialidad" />
                    <TextField fx:id="txtEspecialidad" prefHeight="38" promptText="Ingrese la especialidad" style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: white; -fx-prompt-text-fill: #64748b;" />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <!-- FILA 1 DE BOTONES: ACCIONES DE ESCRITURA -->
                <HBox alignment="CENTER" spacing="8">
                    <Button onAction="#guardar" prefHeight="38" prefWidth="95" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Guardar" />
                    <Button onAction="#actualizar" prefHeight="38" prefWidth="95" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Actualizar" />
                    <Button onAction="#eliminar" prefHeight="38" prefWidth="95" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Eliminar" />
                </HBox>

                <!-- FILA 2 DE BOTONES: LEER Y LIMPIAR (Diseño estilizado de control) -->
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 2 0 0 0;">
                    <Button onAction="#leer" prefHeight="38" prefWidth="146" style="-fx-background-color: #d97706; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="🔍 Leer Datos" />
                    <Button onAction="#limpiarFormulario" prefHeight="38" prefWidth="146" style="-fx-background-color: #475569; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="🗑 Limpiar" />
                </HBox>
            </VBox>

            <!-- TARJETA DERECHA: TABLA -->
            <VBox spacing="15" style="-fx-background-color: #1a1c35; -fx-background-radius: 12; -fx-border-color: #2a2e4d; -fx-border-radius: 12; -fx-border-width: 1;" HBox.hgrow="ALWAYS">

                <padding>
                    <Insets bottom="25" left="25" right="25" top="25" />
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" text="Lista de Profesores Registrados" />
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="txtBuscar" prefHeight="35" prefWidth="220" promptText="Buscar profesor..." style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: white; -fx-prompt-text-fill: #64748b;" />
                </HBox>

                <TableView fx:id="tablaProfesores" style="-fx-base: #1a1c35; -fx-control-inner-background: #1a1c35; -fx-background-color: transparent; -fx-table-cell-border-color: #2a2e4d; -fx-padding: 10 0 0 0;" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50" style="-fx-alignment: CENTER; -fx-text-fill: #c0c6d9;" text="ID" />
                        <TableColumn fx:id="colNombre" prefWidth="100" style="-fx-text-fill: white;" text="NOMBRE" />
                        <TableColumn fx:id="colApellido" prefWidth="100" style="-fx-text-fill: white;" text="APELLIDO" />
                        <TableColumn fx:id="colCedula" prefWidth="100" style="-fx-text-fill: #c0c6d9;" text="CÉDULA" />
                        <TableColumn fx:id="colEspecialidad" prefWidth="120" style="-fx-text-fill: #c0c6d9;" text="ESPECIALIDAD" />
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </children>
</AnchorPane>
