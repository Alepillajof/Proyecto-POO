<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.proyecto.proyecto_poo.controller.ProfesorController"
            prefWidth="780"
            prefHeight="520">

    <children>

        <Label layoutX="25" layoutY="20"
               text="Gestión de Profesores"
               style="-fx-font-size:22px;-fx-font-weight:bold;"/>

        <Label layoutX="25" layoutY="70" text="Nombre"/>

        <TextField fx:id="txtNombre"
                   layoutX="120"
                   layoutY="65"
                   prefWidth="220"/>

        <Label layoutX="25" layoutY="110" text="Apellido"/>

        <TextField fx:id="txtApellido"
                   layoutX="120"
                   layoutY="105"
                   prefWidth="220"/>

        <Label layoutX="25" layoutY="150" text="Cédula"/>

        <TextField fx:id="txtCedula"
                   layoutX="120"
                   layoutY="145"
                   prefWidth="220"/>

        <Label layoutX="25" layoutY="190" text="Especialidad"/>

        <TextField fx:id="txtEspecialidad"
                   layoutX="120"
                   layoutY="185"
                   prefWidth="220"/>

        <Label layoutX="25" layoutY="230" text="Correo"/>

        <TextField fx:id="txtCorreo"
                   layoutX="120"
                   layoutY="225"
                   prefWidth="220"/>

        <Button text="Guardar"
                layoutX="25"
                layoutY="280"
                prefWidth="100"
                onAction="#guardar"/>

        <Button text="Actualizar"
                layoutX="140"
                layoutY="280"
                prefWidth="100"
                onAction="#actualizar"/>

        <Button text="Eliminar"
                layoutX="255"
                layoutY="280"
                prefWidth="100"
                onAction="#eliminar"/>

        <TableView fx:id="tablaProfesores"
                   layoutX="370"
                   layoutY="65"
                   prefWidth="390"
                   prefHeight="380">

            <columns>

                <TableColumn fx:id="colId"
                             text="ID"
                             prefWidth="50"/>

                <TableColumn fx:id="colNombre"
                             text="Nombre"
                             prefWidth="90"/>

                <TableColumn fx:id="colApellido"
                             text="Apellido"
                             prefWidth="90"/>

                <TableColumn fx:id="colCedula"
                             text="Cédula"
                             prefWidth="90"/>

                <TableColumn fx:id="colEspecialidad"
                             text="Especialidad"
                             prefWidth="120"/>

            </columns>

        </TableView>

    </children>

</AnchorPane>