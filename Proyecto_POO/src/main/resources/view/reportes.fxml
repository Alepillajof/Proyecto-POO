<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.proyecto.proyecto_poo.controller.ReporteController"
            prefWidth="950"
            prefHeight="650"
            style="-fx-background-color: transparent;">

    <children>
        <!-- TÍTULO Y SUBTÍTULO -->
        <VBox AnchorPane.topAnchor="10" AnchorPane.leftAnchor="40">
            <Label text="Gestión de Reportes" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Administra y visualiza los reportes académicos." style="-fx-font-size: 13px; -fx-text-fill: #8b95a5; -fx-padding: 5 0 0 0;"/>
        </VBox>

        <!-- CONTENEDOR PRINCIPAL -->
        <HBox spacing="20" AnchorPane.topAnchor="90" AnchorPane.leftAnchor="40" AnchorPane.rightAnchor="40" AnchorPane.bottomAnchor="30">

            <!-- TARJETA IZQUIERDA: FORMULARIO -->
            <VBox spacing="15" prefWidth="350"
                  style="-fx-background-color: #1a1c35; -fx-background-radius: 12; -fx-border-color: #2a2e4d; -fx-border-radius: 12; -fx-border-width: 1;">

                <padding>
                    <Insets top="25" bottom="25" left="25" right="25"/>
                </padding>

                <Label text="Detalles del Reporte" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 5 0;"/>

                <VBox spacing="5">
                    <Label text="Título" style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px;"/>
                    <TextField fx:id="txtTitulo" promptText="Título del reporte" prefHeight="40" style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-text-fill: white;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Descripción" style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px;"/>
                    <TextArea fx:id="txtDescripcion" promptText="Descripción detallada..." prefHeight="100" style="-fx-control-inner-background: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-text-fill: white;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Fecha" style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px;"/>
                    <DatePicker fx:id="dpFecha" prefWidth="300" prefHeight="40" style="-fx-background-color: #12142b;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="ID Usuario" style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px;"/>
                    <TextField fx:id="txtUsuarioId" promptText="ID del usuario" prefHeight="40" style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-text-fill: white;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <!-- Botones -->
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Guardar" onAction="#guardar" prefWidth="95" prefHeight="38" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="Actualizar" onAction="#actualizar" prefWidth="95" prefHeight="38" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="Eliminar" onAction="#eliminar" prefWidth="95" prefHeight="38" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- TARJETA DERECHA: TABLA -->
            <VBox spacing="15" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #1a1c35; -fx-background-radius: 12; -fx-border-color: #2a2e4d; -fx-border-radius: 12; -fx-border-width: 1;">

                <padding>
                    <Insets top="25" bottom="25" left="25" right="25"/>
                </padding>

                <Label text="Historial de Reportes" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                <TableView fx:id="tablaReportes" VBox.vgrow="ALWAYS"
                           style="-fx-base: #1a1c35; -fx-control-inner-background: #1a1c35; -fx-background-color: transparent; -fx-table-cell-border-color: #2a2e4d;">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="40" style="-fx-text-fill: #c0c6d9;"/>
                        <TableColumn fx:id="colTitulo" text="TÍTULO" prefWidth="100" style="-fx-text-fill: white;"/>
                        <TableColumn fx:id="colDescripcion" text="DESCRIPCIÓN" prefWidth="150" style="-fx-text-fill: white;"/>
                        <TableColumn fx:id="colFecha" text="FECHA" prefWidth="80" style="-fx-text-fill: #c0c6d9;"/>
                        <TableColumn fx:id="colUsuarioId" text="USR ID" prefWidth="60" style="-fx-text-fill: #c0c6d9;"/>
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </children>
</AnchorPane>