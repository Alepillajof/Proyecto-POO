<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650" prefWidth="950" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.proyecto_poo.controller.EstudianteController">

    <children>
        <VBox AnchorPane.leftAnchor="40" AnchorPane.topAnchor="10">
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Mi Panel Académico" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #8b95a5;" text="Visualiza tu información personal y los reportes detallados." />
        </VBox>

        <HBox spacing="20" AnchorPane.bottomAnchor="30" AnchorPane.leftAnchor="40" AnchorPane.rightAnchor="40" AnchorPane.topAnchor="90">

            <VBox prefWidth="300" spacing="10" style="-fx-background-color: #1a1c35; -fx-background-radius: 12; -fx-border-color: #2a2e4d; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 10 0;" text="Mis Datos Personales" />

                <Label style="-fx-text-fill: #c0c6d9;" text="Nombre" />
                <TextField fx:id="txtNombre" editable="false" style="-fx-background-color: #12142b; -fx-text-fill: white; -fx-border-color: #2a2e4d; -fx-border-radius: 5;" />

                <Label style="-fx-text-fill: #c0c6d9;" text="Apellido" />
                <TextField fx:id="txtApellido" editable="false" style="-fx-background-color: #12142b; -fx-text-fill: white; -fx-border-color: #2a2e4d; -fx-border-radius: 5;" />

                <Label style="-fx-text-fill: #c0c6d9;" text="Cédula" />
                <TextField fx:id="txtCedula" editable="false" style="-fx-background-color: #12142b; -fx-text-fill: white; -fx-border-color: #2a2e4d; -fx-border-radius: 5;" />

                <Label style="-fx-text-fill: #c0c6d9;" text="Carrera" />
                <TextField fx:id="txtCarrera" editable="false" style="-fx-background-color: #12142b; -fx-text-fill: white; -fx-border-color: #2a2e4d; -fx-border-radius: 5;" />

                <Label style="-fx-text-fill: #c0c6d9;" text="Nivel" />
                <TextField fx:id="txtNivel" editable="false" style="-fx-background-color: #12142b; -fx-text-fill: white; -fx-border-color: #2a2e4d; -fx-border-radius: 5;" />

                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#leer" prefWidth="300" prefHeight="45" style="-fx-background-color: #d97706; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="🔍 Leer Mis Datos" />
            </VBox>

            <VBox spacing="15" HBox.hgrow="ALWAYS">
                <TableView fx:id="tablaDatosEstudiante" prefHeight="250" style="-fx-base: #1a1c35; -fx-control-inner-background: #1a1c35; -fx-table-cell-border-color: #2a2e4d;">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colTituloReporte" text="TÍTULO REPORTE" />
                        <TableColumn fx:id="colNombreProfesor" text="PROFESOR" />
                        <TableColumn fx:id="colEspecialidadProfesor" text="ESPECIALIDAD" />
                    </columns>
                </TableView>

                <TableView fx:id="tablaDescripcion" fixedCellSize="100" style="-fx-base: #1a1c35; -fx-control-inner-background: #1a1c35; -fx-table-cell-border-color: #2a2e4d;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colDescripcion" prefWidth="600" text="DESCRIPCIÓN ACADÉMICA DETALLADA" />
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </children>
</AnchorPane>