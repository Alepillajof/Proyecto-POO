<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650" prefWidth="950" style="-fx-background-color: transparent;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.proyecto.proyecto_poo.controller.EstudianteController"> <!-- Hereda el fondo del dashboard -->

    <children>
        <!-- TÍTULO Y SUBTÍTULO -->
        <VBox AnchorPane.leftAnchor="40" AnchorPane.topAnchor="10">
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Gestión de Estudiantes" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #8b95a5; -fx-padding: 5 0 0 0;" text="Administra la información de los estudiantes del sistema." />
        </VBox>

        <!-- Botón Nuevo -->
        <Button fx:id="btnNuevoEstudiante" prefHeight="40" prefWidth="150" style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="+ Nuevo Estudiante" AnchorPane.rightAnchor="40" AnchorPane.topAnchor="15" />

        <!-- CONTENEDOR PRINCIPAL -->
        <HBox spacing="20" AnchorPane.bottomAnchor="30" AnchorPane.leftAnchor="40" AnchorPane.rightAnchor="40" AnchorPane.topAnchor="90">

            <!-- TARJETA IZQUIERDA: FORMULARIO -->
            <VBox prefWidth="350" spacing="15" style="-fx-background-color: #1a1c35; -fx-background-radius: 12; -fx-border-color: #2a2e4d; -fx-border-radius: 12; -fx-border-width: 1;">

                <padding>
                    <Insets bottom="25" left="25" right="25" top="25" />
                </padding>

                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 5 0;" text="Información del Estudiante" />

                <!-- Campos -->
                <VBox spacing="5">
                    <Label style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px;" text="Nombre" />
                    <TextField fx:id="txtNombre" prefHeight="40" promptText="Nombre" style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: white;" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px;" text="Apellido" />
                    <TextField fx:id="txtApellido" prefHeight="40" promptText="Apellido" style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: white;" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px;" text="Cédula" />
                    <TextField fx:id="txtCedula" prefHeight="40" promptText="Cédula" style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: white;" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px;" text="Carrera" />
                    <TextField fx:id="txtCarrera" prefHeight="40" promptText="Carrera" style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: white;" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px;" text="Nivel" />
                    <TextField fx:id="txtNivel" prefHeight="40" promptText="Nivel" style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: white;" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-text-fill: #c0c6d9; -fx-font-size: 12px;" text="Correo" />
                    <TextField fx:id="txtCorreo" prefHeight="40" promptText="Correo" style="-fx-background-color: #12142b; -fx-border-color: #2a2e4d; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: white;" />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <!-- Botones -->
                <HBox alignment="CENTER" spacing="10">
                    <Button onAction="#guardar" prefHeight="38" prefWidth="95" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Guardar" />
                    <Button onAction="#actualizar" prefHeight="38" prefWidth="95" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Actualizar" />
                    <Button onAction="#eliminar" prefHeight="38" prefWidth="95" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Eliminar" />
                </HBox>
            </VBox>

            <!-- TARJETA DERECHA: TABLA -->
            <VBox spacing="15" style="-fx-background-color: #1a1c35; -fx-background-radius: 12; -fx-border-color: #2a2e4d; -fx-border-radius: 12; -fx-border-width: 1;" HBox.hgrow="ALWAYS">

                <padding>
                    <Insets bottom="25" left="25" right="25" top="25" />
                </padding>

                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" text="Lista de Estudiantes" />

                <TableView fx:id="tablaEstudiantes" style="-fx-base: #1a1c35; -fx-control-inner-background: #1a1c35; -fx-background-color: transparent; -fx-table-cell-border-color: #2a2e4d;" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="40" style="-fx-text-fill: #c0c6d9;" text="ID" />
                        <TableColumn fx:id="colNombre" prefWidth="90" style="-fx-text-fill: white;" text="NOMBRE" />
                        <TableColumn fx:id="colApellido" prefWidth="90" style="-fx-text-fill: white;" text="APELLIDO" />
                        <TableColumn fx:id="colCedula" prefWidth="80" style="-fx-text-fill: #c0c6d9;" text="CÉDULA" />
                        <TableColumn fx:id="colCarrera" prefWidth="80" style="-fx-text-fill: #c0c6d9;" text="CARRERA" />
                        <TableColumn fx:id="colNivel" prefWidth="50" style="-fx-text-fill: #c0c6d9;" text="NIVEL" />
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </children>
</AnchorPane>
