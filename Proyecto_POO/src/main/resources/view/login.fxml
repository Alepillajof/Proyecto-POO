<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.proyecto.proyecto_poo.controller.LoginController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #0b0c1b;"> <!-- Fondo profundo -->

    <children>
        <!-- Tarjeta de Login Glassmorphic -->
        <VBox alignment="CENTER"
              prefWidth="450" prefHeight="550"
              AnchorPane.topAnchor="50" AnchorPane.leftAnchor="225"
              style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 20; -fx-border-color: rgba(255, 255, 255, 0.1); -fx-border-radius: 20; -fx-border-width: 1;">

            <padding>
                <Insets top="40" bottom="40" left="40" right="40"/>
            </padding>

            <!-- Icono superior (Logo) -->
            <StackPane prefWidth="80" prefHeight="80" style="-fx-background-color: rgba(124, 58, 237, 0.2); -fx-background-radius: 40;">
                <Label text="🎓" style="-fx-font-size: 30px;"/>
                <VBox.margin> <Insets bottom="20"/> </VBox.margin>
            </StackPane>

            <Label text="SISTEMA EDUCATIVO" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="Inicia sesión para continuar" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-padding: 0 0 30 0;"/>

            <!-- Campos -->
            <TextField fx:id="txtUsuario" promptText="Usuario" prefHeight="50"
                       style="-fx-background-color: rgba(18, 20, 43, 0.6); -fx-border-color: #312e81; -fx-border-radius: 8; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 0 15;"/>

            <PasswordField fx:id="txtContrasena" promptText="Contraseña" prefHeight="50"
                           style="-fx-background-color: rgba(18, 20, 43, 0.6); -fx-border-color: #312e81; -fx-border-radius: 8; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 0 15;">
                <VBox.margin> <Insets top="15" bottom="25"/> </VBox.margin>
            </PasswordField>

            <!-- Botón Ingresar -->
            <Button fx:id="btnIngresar" text="INGRESAR" onAction="#iniciarSesion"
                    prefWidth="400" prefHeight="50"
                    style="-fx-background-color: linear-gradient(to right, #7c3aed, #4f46e5); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Label text="o continúa con" style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-padding: 20 0 20 0;"/>

            <!-- Icono pequeño abajo -->
            <StackPane prefWidth="40" prefHeight="40" style="-fx-border-color: #312e81; -fx-border-radius: 20; -fx-border-width: 1;">
                <Label text="🛡️" style="-fx-text-fill: white;"/>
            </StackPane>

            <HBox alignment="CENTER" spacing="5">
                <VBox.margin> <Insets top="30"/> </VBox.margin>
                <Label text="¿Olvidaste tu contraseña?" style="-fx-text-fill: #94a3b8;"/>
                <Hyperlink text="Recuperar acceso" style="-fx-text-fill: #818cf8;"/>
            </HBox>
        </VBox>
    </children>
</AnchorPane>