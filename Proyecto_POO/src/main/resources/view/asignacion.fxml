<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="603.0" prefWidth="1014.0" style="-fx-background-color: #131928;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.proyecto_poo.controller.AsignacionController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>

                <VBox spacing="5.0">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="Gestión de Asignaciones" />
                        <Label style="-fx-text-fill: #c0c6d9; -fx-font-size: 14px;" text="Asigna estudiantes a profesores para el seguimiento académico." />
                    </children>
                </VBox>

                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>

                        <VBox prefWidth="300.0" spacing="15.0" style="-fx-background-color: #1b2234; -fx-background-radius: 8; -fx-padding: 20;">
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" text="Detalles de la Asignación" />

                                <VBox spacing="5.0">
                                    <Label style="-fx-text-fill: #c0c6d9;" text="ID Profesor" />
                                    <TextField fx:id="txtProfesorId" promptText="ID del profesor" style="-fx-background-color: #131928; -fx-text-fill: white; -fx-border-color: #313d5a; -fx-border-radius: 4;" />
                                </VBox>

                                <VBox spacing="5.0">
                                    <Label style="-fx-text-fill: #c0c6d9;" text="ID Estudiante" />
                                    <TextField fx:id="txtEstudianteId" promptText="ID del estudiante" style="-fx-background-color: #131928; -fx-text-fill: white; -fx-border-color: #313d5a; -fx-border-radius: 4;" />
                                </VBox>

                                <VBox spacing="5.0">
                                    <Label style="-fx-text-fill: #c0c6d9;" text="Estado" />
                                    <ComboBox fx:id="cmbEstado" prefWidth="260.0" style="-fx-background-color: #131928; -fx-text-fill: white; -fx-border-color: #313d5a;" />
                                </VBox>

                                <HBox alignment="CENTER" spacing="10.0">
                                    <padding><Insets top="10.0" /></padding>
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#guardar" prefWidth="80.0" style="-fx-background-color: #00b894; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Guardar" />
                                        <Button mnemonicParsing="false" onAction="#actualizar" prefWidth="80.0" style="-fx-background-color: #0984e3; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Actualizar" />
                                        <Button mnemonicParsing="false" onAction="#eliminar" prefWidth="80.0" style="-fx-background-color: #d63031; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Eliminar" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#leer" prefWidth="120.0" style="-fx-background-color: #e17055; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text=" Leer" />
                                        <Button mnemonicParsing="false" onAction="#limpiar" prefWidth="120.0" style="-fx-background-color: #636e72; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Limpiar" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" style="-fx-background-color: #1b2234; -fx-background-radius: 8; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" text="Historial de Asignaciones" />
                                <TableView fx:id="tablaAsignaciones" style="-fx-background-color: #131928; -fx-border-color: #313d5a;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                        <TableColumn fx:id="colProfesor" prefWidth="90.0" text="ID PROF" />
                                        <TableColumn fx:id="colEstudiante" prefWidth="150.0" text="ESTUDIANTE" />
                                        <TableColumn fx:id="colCedula" prefWidth="100.0" text="CÉDULA" />
                                        <TableColumn fx:id="colCarrera" prefWidth="120.0" text="CARRERA" />
                                        <TableColumn fx:id="colEstado" prefWidth="100.0" text="ESTADO" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
