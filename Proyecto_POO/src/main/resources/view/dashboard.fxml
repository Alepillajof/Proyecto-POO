<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.proyecto.proyecto_poo.controller.DashboardController"
            prefWidth="1200"
            prefHeight="750"
            style="-fx-background-color: #12142b;">

    <!-- VINCULACIÓN AL ARCHIVO CSS -->
    <stylesheets>
        <URL value="@../css/estilos.css" />
    </stylesheets>

    <!-- BARRA SUPERIOR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="80" style="-fx-padding: 0 30 0 280;">
            <VBox alignment="CENTER_LEFT">
                <HBox>
                    <Label text="¡Bienvenido, " style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblUsuario" text="Usuario" style="-fx-text-fill: #7c3aed; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </HBox>
                <Label text="Sistema de Gestión Educativa" style="-fx-text-fill: #8b95a5; -fx-font-size: 13px;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" style="-fx-background-color: #1e1b4b; -fx-background-radius: 8; -fx-padding: 5 15;">
                <Label fx:id="lblRol" text="Rol: ---" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>
    </top>

    <!-- MENÚ LATERAL -->
    <left>
        <VBox spacing="15" prefWidth="250" style="-fx-background-color: #0b0c1b; -fx-padding: 30 15 20 15; -fx-border-color: #1e2240; -fx-border-width: 0 1 0 0;">

            <VBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 30 10;">
                <Label text="Gestión Educativa" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- AHORA USAMOS styleClass="boton-menu" -->
            <Button fx:id="btnProfesores" text="Profesores" onAction="#abrirProfesores"
                    prefWidth="220" prefHeight="45" styleClass="boton-menu"/>

            <Button fx:id="btnEstudiantes" text="Estudiantes" onAction="#abrirEstudiantes"
                    prefWidth="220" prefHeight="45" styleClass="boton-menu"/>

            <Button fx:id="btnReportes" text="Reportes" onAction="#abrirReportes"
                    prefWidth="220" prefHeight="45" styleClass="boton-menu"/>

            <Region VBox.vgrow="ALWAYS" />

            <!-- USAMOS styleClass="boton-cerrar" -->
            <Button text="Cerrar sesión" onAction="#cerrarSesion"
                    prefWidth="220" prefHeight="45" styleClass="boton-cerrar"/>
        </VBox>
    </left>

    <!-- ÁREA DE CONTENIDO -->
    <center>
        <AnchorPane fx:id="panelPrincipal" style="-fx-background-color: transparent;"/>
    </center>

</BorderPane>