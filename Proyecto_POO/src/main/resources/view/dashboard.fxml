<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="750" prefWidth="1200" style="-fx-background-color: #12142b;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.proyecto_poo.controller.DashboardController">

    <stylesheets>
        <URL value="@../css/estilos.css" />
    </stylesheets>

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="80" style="-fx-padding: 0 30 0 280;">
            <VBox alignment="CENTER_LEFT">
                <HBox>
                    <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="¡Bienvenido, " />
                    <Label fx:id="lblUsuario" style="-fx-text-fill: #7c3aed; -fx-font-size: 22px; -fx-font-weight: bold;" text="Usuario" />
                </HBox>
                <Label style="-fx-text-fill: #8b95a5; -fx-font-size: 13px;" text="Sistema de Gestión Educativa" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" style="-fx-background-color: #1e1b4b; -fx-background-radius: 8; -fx-padding: 5 15;">
                <Label fx:id="lblRol" style="-fx-text-fill: white; -fx-font-weight: bold;" text="Rol: ---" />
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="250" spacing="15" style="-fx-background-color: #0b0c1b; -fx-padding: 30 15 20 15; -fx-border-color: #1e2240; -fx-border-width: 0 1 0 0;">

            <VBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 30 10;">
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Gestión Educativa" />
            </VBox>

            <Button fx:id="btnProfesores" onAction="#abrirProfesores" prefHeight="45" prefWidth="220" styleClass="boton-menu" text="Profesores" />

            <Button fx:id="btnEstudiantes" onAction="#abrirEstudiantes" prefHeight="45" prefWidth="220" styleClass="boton-menu" text="Vista Estudiante" />

            <Button fx:id="btnReportes" onAction="#abrirReportes" prefHeight="45" prefWidth="220" styleClass="boton-menu" text="Reportes" />

            <!-- NUEVO: Botón para la vista individual del panel del estudiante -->
            <Button fx:id="btnMiPanelEstudiante" onAction="#abrirMiPanelEstudiante" prefHeight="45" prefWidth="220" styleClass="boton-menu" text="Estudiantes" />

            <Button fx:id="btnAsignacion" onAction="#abrirAsignaciones" prefHeight="45" prefWidth="220" styleClass="boton-menu" text="Asignación" />

            <Region VBox.vgrow="ALWAYS" />

            <Button onAction="#cerrarSesion" prefHeight="45" prefWidth="220" styleClass="boton-cerrar" text="Cerrar sesión" />
        </VBox>
    </left>


    <center>
        <StackPane fx:id="panelPrincipal" style="-fx-background-color: transparent;" />
    </center>

</BorderPane>
